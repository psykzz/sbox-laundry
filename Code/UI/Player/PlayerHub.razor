@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
	@if (RoundManager.Instance is not null)
	{
		<div class="round-timer">Round @RoundManager.Instance.Round &mdash; @FormatTime(RoundManager.Instance.TimeRemaining)</div>
		<div class="score">⭐ @RoundManager.Instance.Score</div>
	}
	<div class="crosshair"></div>
</root>

@code
{
	string FormatTime(float seconds)
	{
		int m = (int)(seconds / 60f);
		int s = (int)(seconds % 60f);
		return $"{m:D2}:{s:D2}";
	}

	protected override int BuildHash() => System.HashCode.Combine(
		RoundManager.Instance?.Score,
		(int)(RoundManager.Instance?.TimeRemaining ?? 0f)
	);
}
